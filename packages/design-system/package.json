{
  "name": "@strongorange/ds-ui",
  "version": "0.1.1",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/styles.css",
    "./tailwind.config": "./tailwind.config.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "sideEffects": [
    "dist/styles.css"
  ],
  "scripts": {
    "build": "tsup && postcss src/styles.css -o dist/styles.css",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "publish:gh": "npm publish --registry=https://npm.pkg.github.com",
    "release:patch": "npm version patch && npm run build && npm run publish:gh",
    "release:minor": "npm version minor && npm run build && npm run publish:gh",
    "release:major": "npm version major && npm run build && npm run publish:gh"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^3.3.5",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
